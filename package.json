{
  "name": "adorio",
  "private": true,
  "version": "0.1.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "homepage": "https://adorio.space/",
  "scripts": {
    "dev": "next dev --turbopack -p 3001",
    "dev:full": "concurrently --names \"BACKEND,FRONTEND\" --prefix-colors \"blue,green\" \"npm run backend\" \"npm run dev\"",
    "dev:backend": "npm run backend",
    "skibidi": "npm run dev:full",
    "backend": "cd backend && npm run dev",
    "build": "next build",
    "start": "next start -p 3001",
    "start:all": "concurrently --names \"BACKEND,FRONTEND\" --prefix-colors \"blue,green\" \"cd backend && npm start\" \"next start -p 3001\"",
    "deps:sync-platform": "node scripts/sync-platform-deps.cjs",
    "os:refresh": "npm run deps:sync-platform",
    "test": "npm run test:dev",
    "test:integration": "jest --runInBand",
    "docker:preflight": "sh -c 'docker run --rm --network bridge alpine:latest true >/dev/null 2>&1 || { echo \"Docker bridge networking is unavailable.\"; exit 1; }'",
    "docker:dev:up": "docker compose -f docker-compose.yml up -d --build --remove-orphans",
    "docker:dev:down": "docker compose -f docker-compose.yml down --remove-orphans",
    "docker:prod:up": "docker compose -f docker-compose.prod.yml up -d --build --remove-orphans",
    "docker:prod:down": "docker compose -f docker-compose.prod.yml down --remove-orphans",
    "test:dev": "sh -c 'set -e; npm run docker:preflight; cleanup() { docker compose -f docker-compose.yml down --remove-orphans || true; }; trap cleanup EXIT; docker compose -f docker-compose.yml down --remove-orphans || true; docker compose -f docker-compose.yml up -d --build --remove-orphans; node scripts/wait-for-url.cjs http://localhost:8080/api/health 180000 1000; npm run test:integration'",
    "test:prod": "sh -c 'set -e; npm run docker:preflight; cleanup() { docker compose -f docker-compose.prod.yml down --remove-orphans || true; }; trap cleanup EXIT; docker compose -f docker-compose.prod.yml down --remove-orphans || true; docker compose -f docker-compose.prod.yml up -d --build --remove-orphans; node scripts/wait-for-url.cjs http://localhost:8080/api/health 240000 1000; npm run test:integration'",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx}\" \"*.{ts,js,mjs,cjs,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx}\" \"*.{ts,js,mjs,cjs,json}\"",
    "nginx-logs": "sudo tail -f /var/log/nginx/error.log",
    "audit": "node scripts/audit.mjs",
    "audit:local": "node scripts/audit.mjs http://localhost:8080",
    "prepare": "husky"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.19.0",
    "@codemirror/lang-javascript": "^6.2.2",
    "@codemirror/legacy-modes": "^6.5.1",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@emoji-mart/data": "^1.2.1",
    "@emoji-mart/react": "^1.1.1",
    "@heroicons/react": "^2.2.0",
    "@lezer/javascript": "^1.5.4",
    "@reduxjs/toolkit": "^2.5.1",
    "@tanstack/react-query": "^5.66.0",
    "@tanstack/react-virtual": "^3.13.2",
    "@uiw/codemirror-theme-dracula": "^4.25.2",
    "@uiw/codemirror-theme-tokyo-night": "^4.25.2",
    "@uiw/codemirror-themes": "^4.25.2",
    "@uiw/react-codemirror": "^4.23.5",
    "axios": "^1.7.9",
    "dompurify": "^3.2.4",
    "emoji-mart": "^5.6.0",
    "framer-motion": "^12.0.6",
    "lodash": "^4.17.21",
    "lucide-react": "^0.474.0",
    "moment": "^2.30.1",
    "next": "^16.2.4",
    "puppeteer": "^24.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-redux": "^9.2.0",
    "recharts": "^3.2.1",
    "socket.io-client": "^4.8.1",
    "unique-names-generator": "^4.7.1"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx,js,jsx}": "prettier --write",
    "*.{ts,js,mjs,cjs,json}": "prettier --write"
  },
  "jest": {
    "modulePathIgnorePatterns": [
      "<rootDir>/.next/"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "axe-core": "^4.11.3",
    "concurrently": "^9.2.1",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.3.1",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lighthouse": "^13.1.0",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.3",
    "prettier": "^3.8.3",
    "ssl-checker": "^3.0.1",
    "supertest": "^7.0.0",
    "tailwind-scrollbar": "^3.0.0",
    "tailwindcss": "^3.4.3"
  }
}
