{
  "name": "new-adorio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "clean:install": "rm -rf node_modules package-lock.json bun.lock && bun install",
    "dev": "next dev",
    "build": "rm -rf .next && next build && cp -r ./public ./.next/standalone/",
    "start": "bun .next/standalone/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . && tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev && prisma generate",
    "prisma:migrate:deploy": "prisma migrate deploy && prisma generate",
    "prisma:studio": "prisma studio",
    "postinstall": "prisma generate",
    "docker:build": "docker build --target runner -t new-adorio:latest .",
    "docker:run": "docker run -d --name new-adorio -p 3000:3000 --env-file .env new-adorio:latest",
    "docker:logs": "docker logs -f new-adorio",
    "docker:rm": "docker rm -f new-adorio || true",
    "docker:clean:image": "docker rmi -f new-adorio:latest || true",
    "docker:clean:all": "bun run docker:rm && bun run docker:clean:image",
    "docker:rebuild": "bun run docker:clean:all && bun run docker:build && bun run docker:run",
    "docker:dev:up": "docker compose -f docker-compose.dev.yml up --build",
    "docker:dev:down": "docker compose -f docker-compose.dev.yml down",
    "docker:dev:logs": "docker compose -f docker-compose.dev.yml logs -f",
    "docker:prod:up": "docker compose up -d --build",
    "docker:prod:down": "docker compose down",
    "docker:prod:logs": "docker compose logs -f"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.0.0",
    "@better-auth/prisma-adapter": "^1.6.0",
    "@prisma/client": "^7.6.0",
    "@radix-ui/react-slot": "^1.2.4",
    "better-auth": "^1.6.0",
    "browser-image-compression": "^2.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "filesize": "^11.0.14",
    "framer-motion": "^12.38.0",
    "immer": "^11.1.4",
    "lodash-es": "^4.17.23",
    "lucide-react": "^1.6.0",
    "next": "^15.3.2",
    "next-themes": "^0.4.6",
    "pg": "^8.16.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "three": "^0.183.2",
    "zod": "^4.0.15"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@next/eslint-plugin-next": "^16.2.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^27.1.0",
    "prisma": "^7.0.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^3.2.4"
  }
}
